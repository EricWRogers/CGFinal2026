# Minecraft-style fire model (layered crossed planes)
# Slightly taller than one block to feel like rising flame.

o minecraft_fire
usemtl fire

vt 0.000000 0.000000
vt 1.000000 0.000000
vt 1.000000 1.000000
vt 0.000000 1.000000

# Plane set 1: diagonal A (large)
v -0.550000 0.000000 -0.550000
v  0.550000 0.000000  0.550000
v  0.550000 1.150000  0.550000
v -0.550000 1.150000 -0.550000
f 1/1 2/2 3/3 4/4
f 4/4 3/3 2/2 1/1

# Plane set 2: diagonal B (large)
v  0.550000 0.000000 -0.550000
v -0.550000 0.000000  0.550000
v -0.550000 1.150000  0.550000
v  0.550000 1.150000 -0.550000
f 5/1 6/2 7/3 8/4
f 8/4 7/3 6/2 5/1

# Plane set 3: front/back card (inner)
v -0.380000 0.000000  0.000000
v  0.380000 0.000000  0.000000
v  0.380000 1.000000  0.000000
v -0.380000 1.000000  0.000000
f 9/1 10/2 11/3 12/4
f 12/4 11/3 10/2 9/1

# Plane set 4: left/right card (inner)
v  0.000000 0.000000 -0.380000
v  0.000000 0.000000  0.380000
v  0.000000 1.000000  0.380000
v  0.000000 1.000000 -0.380000
f 13/1 14/2 15/3 16/4
f 16/4 15/3 14/2 13/1
