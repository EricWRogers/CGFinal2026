# Minecraft-style flower model (crossed planes)
# Origin at block center, height from y=0 to y=1.

o minecraft_flower
usemtl flower

vt 0.000000 0.000000
vt 1.000000 0.000000
vt 1.000000 1.000000
vt 0.000000 1.000000

# Cross plane A
v -0.500000 0.000000 -0.500000
v  0.500000 0.000000  0.500000
v  0.500000 1.000000  0.500000
v -0.500000 1.000000 -0.500000

f 1/1 2/2 3/3 4/4
f 4/4 3/3 2/2 1/1

# Cross plane B
v  0.500000 0.000000 -0.500000
v -0.500000 0.000000  0.500000
v -0.500000 1.000000  0.500000
v  0.500000 1.000000 -0.500000

f 5/1 6/2 7/3 8/4
f 8/4 7/3 6/2 5/1
